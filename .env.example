# PartyKit хост. В деве не задавать — клиент возьмёт localhost:1999.
# В проде после деплоя: VITE_PARTY_HOST=blockduel-party.<your-pk-username>.partykit.dev
VITE_PARTY_HOST=

# Firebase Auth + Firestore. Все 6 нужны для входа через Google и синхронизации.
# Получите в Firebase Console: Project Settings → Web app → SDK setup.
# Без этих переменных кнопка "Войти через Google" просто скрыта, локально всё работает.
VITE_FB_API_KEY=
VITE_FB_AUTH_DOMAIN=
VITE_FB_PROJECT_ID=
VITE_FB_APP_ID=
VITE_FB_STORAGE_BUCKET=
VITE_FB_MESSAGING_SENDER_ID=
